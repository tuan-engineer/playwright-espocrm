{
  "name": "playwright-espocrm",
  "version": "1.0.0",
  "description": "A practical Playwright-TypeScript blueprint for learning how automation works in real projects. Covers Web UI, API, Mobile emulation, and DB testing, and more. Includes GitHub Actions and k6 metrics to show how a simple script evolves into a complete system",
  "main": "index.js",
  "scripts": {
    "// --- Maintenance ---": "Clean and re-sync project state",
    "clean:system": "rimraf node_modules package-lock.json dist",
    "clean:results": "rimraf test-results reports logs",
    "// --- Install ---": "One-click setup for new developers or CI",
    "init": "npm install --force && npx playwright install --with-deps",
    "init:ci": "npm ci && npx playwright install --with-deps chromium",
    "// --- Quality ---": "Linting, Formatting, and Type Safety",
    "formatcheck": "npx prettier --write . && eslint . --fix && tsc --noEmit",
    "formatcheck:ci": "npx prettier --check . && eslint . && tsc --noEmit",
    "// --- Env-based Execution ---": "Run tests with specific environment configs",
    "test:dev": "npx cross-env APP_ENV=dev playwright test",
    "test:staging": "npx cross-env APP_ENV=staging playwright test",
    "test:prod": "npx cross-env APP_ENV=prod playwright test",
    "// --- Advanced Reporting ---": "Allure & Ortoni report management",
    "reports:allure": "npx allure generate reports/allure/allure-results --clean -o reports/allure/allure-report && npx allure open reports/allure/allure-report",
    "reports:ortoni": "npx playwright show-report reports/ortoni",
    "reports:blob": "npx cross-env PLAYWRIGHT_HTML_REPORT=reports/blob playwright merge-reports reports/blob --reporter=html",
    "// --- Performance ---": "K6 load testing",
    "perf:run": "k6 run src/perf-test/script.js",
    "perf:report": "k6 run --out json=test-results/perf-res.json src/perf-test/script.js",
    "// --- Others ---": "Validates all code logic and converts the entire framework into runnable JavaScript",
    "build": "npx tsc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuan-engineer/playwright-espocrm.git"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "typescript",
    "qa-engineer"
  ],
  "author": "tuan-engineer",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/tuan-engineer/playwright-espocrm/issues"
  },
  "homepage": "https://github.com/tuan-engineer/playwright-espocrm#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "ortoni-report": "^4.0.8",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "@faker-js/faker": "^10.4.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "crypto-js": "^4.2.0",
    "zod": "^3.25.76",
    "winston": "^3.19.0",
    "prettier": "^3.8.3",
    "eslint": "^10.2.1",
    "@axe-core/playwright": "^4.11.1",
    "@prisma/client": "^6.19.3",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.2",
    "lighthouse": "^13.1.0",
    "mailosaur": "^11.1.0",
    "mysql2": "^3.22.2",
    "pdfjs-dist": "^4.10.0",
    "prisma": "^6.19.3",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "@eslint/js": "^10.0.1"
  }
}
